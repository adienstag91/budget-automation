# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database ---
# Local dev (Docker Postgres on port 5433, see docker-compose.yml):
DB_HOST=localhost
DB_PORT=5433
DB_NAME=budget_db
DB_USER=budget_user
DB_PASSWORD=budget_password_local_dev

# Managed hosts (Fly.io / Render / Railway) inject a single connection string.
# When DATABASE_URL is set it takes precedence over the DB_* vars above.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- App mode ---
# "real" (default) = production with real data + auth in front.
# "demo" = public showcase; shows a "Demo data" banner and lets scripts.seed_demo
# wipe/seed transactions. NEVER set this on the production app.
APP_MODE=real

# --- App password gate (production only) ---
# When APP_PASSWORD is set, the whole app (pages + API) requires HTTP Basic auth
# with APP_USERNAME / APP_PASSWORD. Leave APP_PASSWORD unset for the demo and
# local dev (open access). /api/health stays exempt for platform health checks.
# APP_USERNAME=admin
# APP_PASSWORD=choose-a-strong-shared-password

# --- LLM categorization (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
REVIEW_THRESHOLD=0.90
ENABLE_LLM=true
# Claude model for LLM categorization. Override if a model is retired
# (a retired model id returns 404 and silently categorizes nothing).
# LLM_MODEL=claude-sonnet-4-6
